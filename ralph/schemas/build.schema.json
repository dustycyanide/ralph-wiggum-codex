{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ralph builder response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "done",
    "status",
    "summary",
    "active_todo_id",
    "todo_status",
    "next_objective",
    "plan_updates",
    "issue_type",
    "issue_detail",
    "confidence",
    "stop_reason"
  ],
  "properties": {
    "done": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "blocked",
        "completed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "active_todo_id": {
      "type": "string"
    },
    "todo_status": {
      "type": "string",
      "enum": [
        "todo",
        "in_progress",
        "done",
        "blocked",
        "deferred",
        "unknown"
      ]
    },
    "next_objective": {
      "type": "string"
    },
    "plan_updates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "issue_type": {
      "type": "string"
    },
    "issue_detail": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "stop_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}

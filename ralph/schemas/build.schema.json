{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ralph builder response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "done",
    "status",
    "summary",
    "next_objective",
    "plan_updates",
    "confidence",
    "stop_reason"
  ],
  "properties": {
    "done": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "blocked",
        "completed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "next_objective": {
      "type": "string"
    },
    "plan_updates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "stop_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}

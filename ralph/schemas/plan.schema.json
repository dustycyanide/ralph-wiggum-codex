{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ralph planner response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "done",
    "status",
    "summary",
    "build_objective",
    "active_queue_id",
    "active_queue_title",
    "active_todo_id",
    "active_todo_title",
    "completion_criteria",
    "plan_updates",
    "confidence",
    "stop_reason"
  ],
  "properties": {
    "done": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "ready",
        "waiting",
        "completed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "build_objective": {
      "type": "string"
    },
    "active_queue_id": {
      "type": "string"
    },
    "active_queue_title": {
      "type": "string"
    },
    "active_todo_id": {
      "type": "string"
    },
    "active_todo_title": {
      "type": "string"
    },
    "completion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "plan_updates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "stop_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}

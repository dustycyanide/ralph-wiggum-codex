{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ralph planner response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "done",
    "summary",
    "build_objective",
    "completion_criteria",
    "confidence",
    "stop_reason"
  ],
  "properties": {
    "done": {
      "type": "boolean"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "build_objective": {
      "type": "string"
    },
    "completion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "stop_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}

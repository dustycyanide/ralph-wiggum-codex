#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="${SCRIPT_DIR}"
SCENARIOS_DIR="${ROOT_DIR}/smoke-scenarios"
REPLAY_PLAN_MODEL="${RALPH_REPLAY_PLAN_MODEL:-gpt-5.2-codex}"
REPLAY_BUILD_MODEL="${RALPH_REPLAY_BUILD_MODEL:-gpt-5.2-codex}"
REPLAY_PLAN_REASONING="${RALPH_REPLAY_PLAN_REASONING:-low}"
REPLAY_BUILD_REASONING="${RALPH_REPLAY_BUILD_REASONING:-low}"

usage() {
  cat <<'EOF'
Usage:
  ./replay-smoke <scenario-name|all> [--keep-run-dir]

Examples:
  ./replay-smoke scenario-1
  ./replay-smoke scenario-5
  ./replay-smoke all

Behavior:
  - Copies the scenario seed plan over IMPLEMENTATION_PLAN.md
  - Removes only the files listed by that scenario before replay
  - Runs ./ralph-loop with replay-optimized model defaults
  - Runs an optional scenario validation script after replay
  - Writes replay runs under .ralph-runs/replays/
EOF
}

if [[ $# -lt 1 ]]; then
  usage
  exit 1
fi

KEEP_RUN_DIR=0
if [[ "${*: -1}" == "--keep-run-dir" ]]; then
  KEEP_RUN_DIR=1
  set -- "${@:1:$(($# - 1))}"
fi

SELECTION="${1}"

timestamp() {
  date +"%Y%m%d-%H%M%S"
}

require_file() {
  local path="$1"
  if [[ ! -f "${path}" ]]; then
    echo "Missing required file: ${path}" >&2
    exit 1
  fi
}

list_scenarios() {
  local path

  for path in "${SCENARIOS_DIR}"/*; do
    if [[ -d "${path}" ]]; then
      basename "${path}"
    fi
  done | sort
}

seed_plan() {
  local scenario_dir="$1"
  require_file "${scenario_dir}/IMPLEMENTATION_PLAN.seed.md"
  cp "${scenario_dir}/IMPLEMENTATION_PLAN.seed.md" "${ROOT_DIR}/IMPLEMENTATION_PLAN.md"
}

clean_scenario_artifacts() {
  local scenario_dir="$1"
  local cleanup_file="${scenario_dir}/cleanup-paths.txt"
  local relative_path=""

  if [[ ! -f "${cleanup_file}" ]]; then
    return 0
  fi

  while IFS= read -r relative_path || [[ -n "${relative_path}" ]]; do
    if [[ -z "${relative_path}" || "${relative_path}" == \#* ]]; then
      continue
    fi
    rm -rf "${ROOT_DIR}/${relative_path}"
  done < "${cleanup_file}"
}

scenario_loops() {
  local scenario_dir="$1"
  local loops_file="${scenario_dir}/loops.txt"

  if [[ -f "${loops_file}" ]]; then
    tr -d '[:space:]' < "${loops_file}"
    return 0
  fi

  echo 2
}

scenario_iterations() {
  local scenario_dir="$1"
  local iterations_file="${scenario_dir}/iterations.txt"

  if [[ -f "${iterations_file}" ]]; then
    tr -d '[:space:]' < "${iterations_file}"
    return 0
  fi

  echo 1
}

run_validation() {
  local scenario_dir="$1"
  local run_dir="$2"
  local validate_script="${scenario_dir}/validate.sh"

  if [[ ! -f "${validate_script}" ]]; then
    return 0
  fi

  bash "${validate_script}" "${ROOT_DIR}" "${run_dir}" "${scenario_dir}"
}

run_prepare() {
  local scenario_dir="$1"
  local prepare_script="${scenario_dir}/prepare.sh"

  if [[ ! -f "${prepare_script}" ]]; then
    return 0
  fi

  bash "${prepare_script}" "${ROOT_DIR}" "${scenario_dir}"
}

run_one() {
  local scenario="$1"
  local scenario_dir="${SCENARIOS_DIR}/${scenario}"
  local task_file="${scenario_dir}/task.txt"
  local run_dir_base="${ROOT_DIR}/.ralph-runs/replays"
  local run_dir="${run_dir_base}/${scenario}-$(timestamp)"
  local loops
  local iterations
  local mutator_pid=""
  local loop_exit_code=0

  require_file "${task_file}"
  mkdir -p "${run_dir_base}"

  echo "==> ${scenario}"
  seed_plan "${scenario_dir}"
  clean_scenario_artifacts "${scenario_dir}"
  run_prepare "${scenario_dir}"

  loops="$(scenario_loops "${scenario_dir}")"
  iterations="$(scenario_iterations "${scenario_dir}")"

  set +e
  if [[ -f "${scenario_dir}/mutate-plan.sh" ]]; then
    bash "${scenario_dir}/mutate-plan.sh" "${run_dir}/loop-01-planner.json" &
    mutator_pid="$!"
    "${ROOT_DIR}/ralph-loop" \
      --run-dir "${run_dir}" \
      --task "$(cat "${task_file}")" \
      --loops "${loops}" \
      --iterations "${iterations}" \
      --sandbox workspace-write \
      --plan-model "${REPLAY_PLAN_MODEL}" \
      --build-model "${REPLAY_BUILD_MODEL}" \
      --plan-reasoning "${REPLAY_PLAN_REASONING}" \
      --build-reasoning "${REPLAY_BUILD_REASONING}" \
      --pause-before-builder-seconds 1
    loop_exit_code=$?
  else
    "${ROOT_DIR}/ralph-loop" \
      --run-dir "${run_dir}" \
      --task "$(cat "${task_file}")" \
      --loops "${loops}" \
      --iterations "${iterations}" \
      --sandbox workspace-write \
      --plan-model "${REPLAY_PLAN_MODEL}" \
      --build-model "${REPLAY_BUILD_MODEL}" \
      --plan-reasoning "${REPLAY_PLAN_REASONING}" \
      --build-reasoning "${REPLAY_BUILD_REASONING}"
    loop_exit_code=$?
  fi
  set -e

  if [[ "${loop_exit_code}" -ne 0 && "${loop_exit_code}" -ne 2 ]]; then
    echo "Replay command failed with exit code ${loop_exit_code}" >&2
    exit "${loop_exit_code}"
  fi

  if [[ -n "${mutator_pid}" ]]; then
    wait "${mutator_pid}"
  fi

  run_validation "${scenario_dir}" "${run_dir}"

  echo "Run directory: ${run_dir}"

  if [[ "${KEEP_RUN_DIR}" -eq 0 ]]; then
    :
  fi
}

if [[ "${SELECTION}" == "all" ]]; then
  for scenario in $(list_scenarios); do
    run_one "${scenario}"
  done
else
  run_one "${SELECTION}"
fi
